# YES BANK UI — Environment Variables
# ─────────────────────────────────────
# The Vite dev server proxies /accounts → http://localhost:8080
# so VITE_API_BASE is empty string in development.
#
# For production builds, set this to your backend URL:
# VITE_API_BASE=http://your-server:8080

VITE_API_BASE=
